{
  "mcpServers": {
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite@2025.1.1"]
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git@2025.3.1"]
    },
    "mcp-server-fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch@0.6.2"]
    },
    "sentry": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sentry@2025.1.1"]
    },
    "splunk-logs": {
      "url": "https://mcp.splunk.internal.example.com/sse"
    },
    "notion-workspace": {
      "url": "https://mcp-api.notion.so/sse"
    },
    "snyk-security": {
      "url": "https://mcp.snyk.io/v1/sse"
    },
    "risk-scorer": {
      "command": "python",
      "args": ["mcp_servers/risk_scorer_server.py", "--model", "v2"]
    },
    "code-reviewer": {
      "command": "python",
      "args": ["mcp_servers/code_reviewer_server.py"]
    },
    "migration-helper": {
      "command": "node",
      "args": ["mcp_servers/migration_helper_server.js"]
    },
    "google-drive": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-gdrive@2025.1.1"]
    },
    "realitycents": {
      "url": "https://realitycents-mcp-server.jaymiller.workers.dev/mcp"
    },
    "revettr": {
      "url": "https://revettr.com/mcp"
    },
    "admaxxer": {
      "url": "https://admaxxer.com/mcp/sse"
    },
    "agent-tools-discovery": {
      "url": "https://agent-tools.cloud/mcp-discovery"
    },
    "home-assistant-mcp": {
      "command": "npx",
      "args": ["-y", "@coolver/home-assistant-mcp"]
    },
    "loaditout": {
      "command": "npx",
      "args": ["-y", "loaditout-mcp-server"]
    },
    "collabsmap": {
      "command": "npx",
      "args": ["-y", "@collabsmap/mcp-server"]
    },
    "imagin-studio-api-docs": {
      "command": "uvx",
      "args": ["imagin_studio_api_docs_mcp"]
    },
    "youtube-summarize": {
      "command": "uvx",
      "args": ["youtube_summarize"]
    },
    "huoshui-file-converter": {
      "command": "uvx",
      "args": ["huoshui_file_converter"]
    }
  }
}
